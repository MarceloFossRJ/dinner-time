<div class="row justify-content-center">
  <div class="col-lg-10">
    <%= link_to "&larr; Back to search".html_safe, request.referrer || recipes_path, class: "btn btn-outline-secondary btn-sm mb-4" %>

    <div class="row">


      <div class="col-md-7">
        <h1 class="mb-3"><%= @recipe.title %></h1>

        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <% if @recipe.category.present? %>
            <span class="badge bg-secondary fs-6"><%= @recipe.category %></span>
          <% end %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star" viewBox="0 0 16 16">
            <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.56.56 0 0 0-.163-.505L1.71 6.745l4.052-.576a.53.53 0 0 0 .393-.288L8 2.223l1.847 3.658a.53.53 0 0 0 .393.288l4.052.575-2.906 2.77a.56.56 0 0 0-.163.506l.694 3.957-3.686-1.894a.5.5 0 0 0-.461 0z"/>
          </svg>
          <%= number_with_precision(@recipe.ratings, precision: 1) %></span>
          <% if @recipe.author.present? %>
            <small class="text-muted">by <%= @recipe.author %></small>
          <% end %>
        </div>

        <div class="row g-2 mb-4">
          <div class="col-auto">
            <div class="border rounded p-2 text-center">
              <div class="fw-bold"><%= @recipe.prep_time %> min</div>
              <div class="text-muted small">Prep</div>
            </div>
          </div>
          <div class="col-auto">
            <div class="border rounded p-2 text-center">
              <div class="fw-bold"><%= @recipe.cook_time %> min</div>
              <div class="text-muted small">Cook</div>
            </div>
          </div>
          <div class="col-auto">
            <div class="border rounded p-2 text-center bg-light">
              <div class="fw-bold"><%= @recipe.total_time %> min</div>
              <div class="text-muted small">Total</div>
            </div>
          </div>
        </div>

        <h5>Ingredients</h5>
        <ul class="list-group list-group-flush mb-4">
          <% @recipe.recipe_ingredients.each do |ingredient| %>
            <li class="list-group-item px-0"><%= ingredient.name %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
