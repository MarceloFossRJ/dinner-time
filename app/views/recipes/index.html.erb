<div class="row justify-content-center">
  <div class="col-lg-10">
    <h1 class="mb-4">Find a Recipe</h1>

    <div class="card mb-4" data-controller="ingredients">
      <div class="card-body">
        <%= form_with url: recipes_path, method: :get, local: true do |f| %>
          <%# Ingredient tag input %>
          <div class="mb-3">
            <label class="form-label fw-semibold">Ingredients you have</label>
            <div class="d-flex gap-2 mb-2">
              <input type="text"
                     class="form-control"
                     placeholder="e.g. chicken, garlic, lemon..."
                     data-ingredients-target="input"
                     data-action="keydown.enter->ingredients#add:prevent">
              <button type="button"
                      class="btn btn-outline-secondary"
                      data-action="click->ingredients#add">
                Add
              </button>
            </div>
            <div class="d-flex flex-wrap gap-2 mb-2" data-ingredients-target="tags">
              <%# Pre-populate tags if ingredients were submitted %>
              <% @ingredients.each do |ing| %>
                <span class="badge bg-primary d-flex align-items-center gap-1 fs-6 fw-normal py-2 px-3 ingredient-pill">
                  <%= ing %>
                  <button type="button"
                          class="btn-close btn-close-white"
                          aria-label="Remove"
                          style="font-size:0.6rem"
                          data-action="click->ingredients#remove">
                  </button>
                  <input type="hidden" name="ingredients[]" value="<%= ing %>">
                </span>
              <% end %>
            </div>
            <small class="text-muted">
              <span data-ingredients-target="count"><%= @ingredients.length %>/3</span> ingredients added
              (minimum 3 required)
            </small>
          </div>

          <%# Filters %>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label">Category</label>
              <%= f.select :category,
                  options_for_select([["All categories", ""]] + @categories.map { |c| [c, c] }, @category),
                  {},
                  class: "form-select" %>
            </div>
            <div class="col-md-6">
              <label class="form-label">Max total time</label>
              <%= f.select :max_time,
                  options_for_select([
                    ["Any time", ""],
                    ["≤ 15 min", 15],
                    ["≤ 30 min", 30],
                    ["≤ 45 min", 45],
                    ["≤ 60 min", 60]
                  ], @max_time),
                  {},
                  class: "form-select" %>
            </div>
          </div>

          <button type="submit"
                  class="btn btn-primary"
                  data-ingredients-target="submit"
                  <%= "disabled" if @ingredients.length < 3 %>>
            Search Recipes
          </button>
        <% end %>
      </div>
    </div>

    <% if @recipes %>
      <p class="text-muted mb-3"><strong><%= @recipes.length %></strong> recipes found</p>
      <div class="row row-cols-1 row-cols-md-3 g-4">
        <% @recipes.each do |recipe| %>
          <div class="col">
            <div class="card h-100">

              <div class="card-body">
                <h5 class="card-title"><%= recipe.title %></h5>
                <% if recipe.category.present? %>
                  <span class="badge bg-secondary mb-2"><%= recipe.category %></span>
                <% end %>
                <p class="card-text mb-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star" viewBox="0 0 16 16">
                    <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.56.56 0 0 0-.163-.505L1.71 6.745l4.052-.576a.53.53 0 0 0 .393-.288L8 2.223l1.847 3.658a.53.53 0 0 0 .393.288l4.052.575-2.906 2.77a.56.56 0 0 0-.163.506l.694 3.957-3.686-1.894a.5.5 0 0 0-.461 0z"/>
                  </svg>
                  <%= number_with_precision(recipe.ratings, precision: 1) %>
                </p>
                <p class="card-text mb-1">
                  <small class="text-muted">
                    <% if recipe.total_time > 0 %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-clock-fill" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/>
                      </svg>
                      <%= recipe.total_time %> min total
                    <% else %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-clock" viewBox="0 0 16 16">
                        <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/>
                        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/>
                      </svg>
                      Time not specified
                    <% end %>
                  </small>
                </p>
                <p class="card-text">
                  <small class="text-success fw-semibold">
                    Matches <%= recipe.match_count %> of your ingredients
                  </small>
                </p>
              </div>
              <div class="card-footer">
                <%= link_to "View Recipe", recipe_path(recipe), class: "btn btn-outline-primary btn-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
