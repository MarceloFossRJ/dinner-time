<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "It's Dinner Time" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "It's Dinner Time", root_path, class: "navbar-brand fw-bold" %>
      </div>
    </nav>

    <% flash.each do |type, message| %>
      <% alert_class = { "success" => "alert-success", "alert" => "alert-warning", "notice" => "alert-info", "error" => "alert-danger" }.fetch(type, "alert-info") %>
      <div class="alert <%= alert_class %> alert-dismissible fade show mb-0" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>

    <div class="container my-4">
      <%= yield %>
    </div>

  </body>
</html>
